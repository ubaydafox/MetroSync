rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: own profile only
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Task completions: each user can only access their own records
    // Document ID format: {uid}_{taskId}
    match /task_completions/{docId} {
      allow read, write: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }

    // ⚠️ TEMPORARY: All collections open for demo seeding.
    // After seeding, restrict writes to admin role only.
    match /departments/{id}    { allow read: if true; allow write: if true; }
    match /batches/{id}        { allow read: if true; allow write: if true; }
    match /teachers/{id}       { allow read: if true; allow write: if true; }
    match /courses/{id}        { allow read: if true; allow write: if true; }
    match /schedules/{id}      { allow read: if true; allow write: if true; }
    match /notices/{id}        { allow read: if true; allow write: if true; }
    match /course_notices/{id} { allow read: if true; allow write: if true; }
    match /tasks/{id}          { allow read: if true; allow write: if true; }
    match /materials/{id}      { allow read: if true; allow write: if true; }
    match /crs/{id}            { allow read: if true; allow write: if true; }
    match /hods/{id}           { allow read: if true; allow write: if true; }
  }
}

